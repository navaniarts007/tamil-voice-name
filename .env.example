# Sarvam AI (Speech-to-Text + LLM) — required.
# Get a key at https://dashboard.sarvam.ai/
SARVAM_API_KEY=
SARVAM_MODEL=saarika:v2.5
SARVAM_LANG=ta-IN
# transcribe (Tamil script) | translit (English direct, recommended) |
# verbatim | translate | codemix
SARVAM_MODE=translit
# sarvam-m (fast) | sarvam-30b | sarvam-105b
SARVAM_LLM_MODEL=sarvam-m
